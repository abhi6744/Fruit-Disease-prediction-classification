<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:background="#0F1115"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:orientation="vertical"
        android:padding="16dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <!-- HEADER -->
        <LinearLayout
            android:background="#1B5E20"
            android:padding="16dp"
            android:orientation="vertical"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Fruit Disease AI"
                android:textColor="#A5D6A7"
                android:textSize="14sp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Detect and Diagnose"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:textSize="22sp"/>
        </LinearLayout>

        <!-- FRUIT BUTTONS -->
        <LinearLayout
            android:orientation="horizontal"
            android:layout_marginTop="16dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <Button
                android:id="@+id/btnApple"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="🍎 Apple"
                android:backgroundTint="#2E7D32"
                android:textColor="#FFFFFF"
                android:layout_weight="1"/>

            <Button
                android:id="@+id/btnOrange"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="🍊 Orange"
                android:layout_marginStart="8dp"
                android:layout_weight="1"/>

            <Button
                android:id="@+id/btnMango"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="🥭 Mango"
                android:layout_marginStart="8dp"
                android:layout_weight="1"/>
        </LinearLayout>

        <!-- IMAGE UPLOAD BOX -->
        <FrameLayout
            android:layout_marginTop="20dp"
            android:layout_width="match_parent"
            android:layout_height="200dp"
            android:background="#1E1E1E">

            <ImageView
                android:id="@+id/imageView"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"/>

            <TextView
                android:id="@+id/txtPlaceholder"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📷 Tap to add image"
                android:textColor="#888"
                android:layout_gravity="center"/>
        </FrameLayout>

        <!-- BUTTONS -->
        <LinearLayout
            android:orientation="horizontal"
            android:layout_marginTop="16dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <Button
                android:id="@+id/btnCamera"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="📷 Camera"
                android:layout_weight="1"/>

            <Button
                android:id="@+id/btnGallery"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="🖼 Gallery"
                android:layout_weight="1"
                android:layout_marginStart="8dp"/>
        </LinearLayout>

        <!-- MODEL STATUS -->
        <LinearLayout
            android:background="#1E1E1E"
            android:padding="12dp"
            android:layout_marginTop="16dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Model loaded: Apple CNN"
                android:textColor="#4CAF50"/>
        </LinearLayout>

        <!-- PREDICT BUTTON -->
        <Button
            android:id="@+id/btnPredict"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Predict Disease →"
            android:layout_marginTop="20dp"
            android:backgroundTint="#2E7D32"
            android:textColor="#FFFFFF"/>

    </LinearLayout>

</ScrollView>