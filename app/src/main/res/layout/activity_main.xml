<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F1F8E9">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Leaf Disease Detector"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="#2E7D32"
            android:gravity="center"
            android:paddingBottom="4dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Select a fruit, then upload or capture a leaf image"
            android:textSize="13sp"
            android:textColor="#555555"
            android:gravity="center"
            android:paddingBottom="20dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Select Fruit"
            android:textSize="15sp"
            android:textStyle="bold"
            android:textColor="#1B5E20"
            android:paddingBottom="8dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:weightSum="3"
            android:paddingBottom="16dp">

            <Button
                android:id="@+id/btnApple"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_weight="1"
                android:layout_marginEnd="4dp"
                android:text="Apple"
                android:textAllCaps="false"
                android:textColor="#FFFFFF"
                android:backgroundTint="#C5B3F2" />

            <Button
                android:id="@+id/btnMango"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_weight="1"
                android:layout_marginHorizontal="4dp"
                android:text="Mango"
                android:textAllCaps="false"
                android:textColor="#FFFFFF"
                android:backgroundTint="#C5B3F2" />

            <Button
                android:id="@+id/btnOrange"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_weight="1"
                android:layout_marginStart="4dp"
                android:text="Orange"
                android:textAllCaps="false"
                android:textColor="#FFFFFF"
                android:backgroundTint="#C5B3F2" />

        </LinearLayout>

        <TextView
            android:id="@+id/tvSelectedFruit"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Selected: Apple"
            android:textSize="14sp"
            android:textColor="#388E3C"
            android:textStyle="bold"
            android:gravity="center"
            android:paddingBottom="12dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Leaf Image"
            android:textSize="15sp"
            android:textStyle="bold"
            android:textColor="#1B5E20"
            android:paddingBottom="8dp" />

        <ImageView
            android:id="@+id/imgPreview"
            android:layout_width="match_parent"
            android:layout_height="240dp"
            android:scaleType="centerCrop"
            android:background="#C8E6C9"
            android:contentDescription="Leaf preview image" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:weightSum="2"
            android:paddingTop="12dp"
            android:paddingBottom="12dp">

            <Button
                android:id="@+id/btnGallery"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_weight="1"
                android:layout_marginEnd="6dp"
                android:text="Gallery"
                android:textAllCaps="false"
                android:textColor="#FFFFFF"
                android:backgroundTint="#388E3C" />

            <Button
                android:id="@+id/btnCamera"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_weight="1"
                android:layout_marginStart="6dp"
                android:text="Camera"
                android:textAllCaps="false"
                android:textColor="#FFFFFF"
                android:backgroundTint="#388E3C" />

        </LinearLayout>

        <Button
            android:id="@+id/btnAnalyse"
            android:layout_width="match_parent"
            android:layout_height="58dp"
            android:layout_marginTop="4dp"
            android:text="Analyse Leaf"
            android:textAllCaps="false"
            android:textSize="17sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:backgroundTint="#1B5E20" />

    </LinearLayout>
</ScrollView>